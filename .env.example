# =============================================================================
# JustSoc 应用层编排配置 — 复制为 .env 后按需修改（docker compose 会自动读取）
#
# Kafka broker 随探针部署，配置见 rules-engine/deploy/.env.example。
# 本文件中 logstash 作为远程消费者，下列 Kafka 取值须与探针侧保持一致。
# =============================================================================

# ---- Kafka 消息总线（logstash 远程消费用）------------------------------------
# 探针侧 Kafka 的对外地址，等于探针 .env 的 KAFKA_EXTERNAL_HOST:KAFKA_EXTERNAL_PORT
KAFKA_BOOTSTRAP=<probe-host>:9092
# SASL/PLAIN 账号密码（须与探针侧 KAFKA_SASL_USERNAME / KAFKA_SASL_PASSWORD 一致）
KAFKA_SASL_USERNAME=kafka
KAFKA_SASL_PASSWORD=<change-me>

# ---- Elasticsearch / Logstash ----------------------------------------------
LOGSTASH_ES_HOSTS=http://elasticsearch:9200

# ---- 控制面数据库 (PostgreSQL) ----------------------------------------------
POSTGRES_DB=selk_controlplane
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<change-me>

# ---- JustSoc Platform -------------------------------------------------------
PLATFORM_PORT=3000
# 会话令牌签名密钥（至少 24 字符）。start.sh 会自动随机生成，留空即可。
SELK_AUTH_SECRET=
# 会话 cookie 的 Secure 标志：留空=按访问协议自动判断；纯 HTTP 部署留空即可。
# 仅当前面有 HTTPS 反向代理时才需要设为 true。
SELK_AUTH_COOKIE_SECURE=
SELK_ELASTICSEARCH_URL=http://elasticsearch:9200
SELK_ELASTICSEARCH_USERNAME=
SELK_ELASTICSEARCH_PASSWORD=
SELK_DEFAULT_USER_KEY=default
SELK_AI_BASE_URL=
SELK_AI_API_KEY=
SELK_AI_MODEL=gpt-4o-mini
SELK_RUNTIME_MONITOR_BASE_URL=http://host.docker.internal:19091

# ---- Claude Code Bridge（与平台同容器运行，不再单独暴露端口）----------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
BRIDGE_ES_ENDPOINT=http://elasticsearch:9200
