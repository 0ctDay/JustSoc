alert http any any -> any any (msg:"命令注入 URI 分隔符与命令链尝试"; flow:to_server,established; http.uri; pcre:"/(?:\?|&)[^=]{1,40}=(?:[^&]{0,96})?(?:\x3b|%3[bB]|&&|\|\|?|%7[cC])(?:\s|%20|%09)*(?:curl|wget|bash(?:\s+-c)?|sh|python(?:3)?(?:\s+-c)?|perl(?:\s+-e)?|php(?:\s+-r)?|cmd(?:\.exe)?|powershell(?:\.exe)?|whoami|id|uname|cat|type|certutil)/Ui"; classtype:web-application-attack; metadata: selk_category 命令执行; priority:2; sid:1002001; rev:3;)
