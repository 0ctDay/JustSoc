alert http any any -> any any (msg:"SQL注入数据库报错响应迹象"; flow:to_client,established; pcre:"/(?:sql syntax.*mysql|warning.*mysql_|mysql_fetch|supplied argument is not a valid mysql|unclosed quotation mark after the character string|microsoft ole db provider for sql server|odbc sql server driver|postgresql.*error|pg_query\(\)\:|sqlite error|ora-\d{5}|sqlstate\[[a-z0-9]{5}\])/Qi"; classtype:web-application-attack; metadata: selk_category SQL注入; priority:1; sid:1009001; rev:1;)
alert http any any -> any any (msg:"文件读取 Linux 敏感内容迹象"; flow:to_client,established; pcre:"/(?:root:x:0:0:|daemon:x:1:1:|nobody:x:|\/bin\/(?:bash|sh)|localhost\.localdomain)/Q"; classtype:web-application-attack; metadata: selk_category 文件读取; priority:1; sid:1009003; rev:1;)
alert http any any -> any any (msg:"命令执行 Unix 输出迹象"; flow:to_client,established; pcre:"/(?:uid=\d+\([^)]+\)|gid=\d+\([^)]+\)|groups=\d+\([^)]+\)|Linux\s+[A-Za-z0-9._-]+\s+\d|www-data|root\s+root)/Q"; classtype:web-application-attack; metadata: selk_category 命令执行; priority:1; sid:1009004; rev:1;)
alert http any any -> any any (msg:"命令执行 Windows 输出迹象"; flow:to_client,established; pcre:"/(?:Volume Serial Number|Directory of [A-Z]:\\\\|\\r?\\n\s*Program Files\\r?\\n|\\r?\\n\s*Windows\\r?\\n|Microsoft Windows \[Version)/Q"; classtype:web-application-attack; metadata: selk_category 命令执行; priority:1; sid:1009005; rev:1;)
alert http any any -> any any (msg:"文件读取 Windows 或配置文件内容迹象"; flow:to_client,established; pcre:"/(?:for 16-bit app support|\[extensions\]|\[fonts\]|\[mci extensions\]|spring\.datasource\.|server\.port=|<web-app[^>]*>|\[boot loader\])/Qi"; classtype:web-application-attack; metadata: selk_category 文件读取; priority:1; sid:1009006; rev:1;)
