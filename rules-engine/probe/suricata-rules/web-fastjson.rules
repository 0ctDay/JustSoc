alert http any any -> any any (msg:"FastJson autoType JSON 请求体尝试"; flow:to_server,established; http.content_type; content:"application/json"; nocase; pkt_data; pcre:"/\"@type\"\s*:\s*\"(?:java\.|javax\.|com\.sun\.|org\.apache\.|org\.springframework\.|com\.alibaba\.)[^\"]+\"/P"; classtype:web-application-attack; metadata: selk_category FastJson; priority:1; sid:1007001; rev:2;)
