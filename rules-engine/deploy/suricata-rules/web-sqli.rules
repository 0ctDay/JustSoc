alert http any any -> any any (msg:"SQL注入 UNION/SELECT URI 参数尝试"; flow:to_server,established; http.uri; content:"union"; nocase; pcre:"/(?:\?|&)[^=]{1,40}=(?:[^&]{0,96})?(?:%27|'|%22|\")?(?:\s|%20|%09|\/\*|\*\/)+(?:union(?:\s|%20|%09|\/\*|\*\/)+(?:all(?:\s|%20|%09|\/\*|\*\/)+)?select)/Ui"; classtype:web-application-attack; metadata: selk_category SQL注入; priority:2; sid:1000001; rev:3;)
