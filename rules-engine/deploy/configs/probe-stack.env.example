# JustSoc probe-side deployment configuration.
# Copy to configs/probe-stack.env, edit this single file, then run:
#   ./init-config.sh    (generates configs/probe.yaml + suricata.generated.yaml)
#   sudo ./install.sh   (generates configs/engine.conf + runtime-monitor.env, installs systemd)

# ----- installation -----
SELK_SYSTEMD_DIR=/etc/systemd/system
SELK_LOG_DIR=/var/log/selk
SELK_RUN_DIR=/run/selk
SELK_PROBE_SERVICE=selk-probe
SELK_ENGINE_SERVICE=justsoc-threat-engine
SELK_DISPATCHER_SERVICE=selk-probe-dispatcher

# ----- probe runtime -----
SELK_PROBE_SENSOR_ID=linux-sensor-01
SELK_PROBE_SITE=linux-lab
SELK_PROBE_ROLE=ids-probe
SELK_PROBE_MODE=managed
SELK_PROBE_OUTPUT=kafka
# Comma-separated values are accepted for multi-interface capture, for example: eth0,eth1
SELK_PROBE_INTERFACE=127.0.0.1
SELK_PROBE_START_POSITION=end
SELK_PROBE_HEALTH_LISTEN=:8081
SELK_PROBE_LOG_LEVEL=debug

# ----- Suricata -----
SELK_SURICATA_BINARY=suricata
SELK_SURICATA_BASE_CONFIG=/etc/suricata/suricata.yaml
SELK_SURICATA_EVE_PATH=/var/log/suricata/eve.json
SELK_SURICATA_LOG_DIR=/var/log/suricata
SELK_SURICATA_HTTP_LOG=true
SELK_SURICATA_HTTP_BODY=true
SELK_SURICATA_DNS_LOG=false
SELK_SURICATA_FLOW_LOG=false

# ----- Kafka shared by probe and threat-engine -----
SELK_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
SELK_KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
SELK_KAFKA_SASL_MECHANISM=PLAIN
SELK_KAFKA_USERNAME=kafka
SELK_KAFKA_PASSWORD=CHANGE_ME
SELK_KAFKA_RAW_TOPIC=selk.suricata.eve
SELK_KAFKA_ENRICHED_TOPIC=selk.alerts.enriched
SELK_ENGINE_CONSUMER_GROUP=justsoc-threat-engine

# ----- threat-engine output -----
SELK_ENGINE_DEBUG=true
SELK_ENGINE_SINK_MODE=kafka
SELK_ENGINE_BATCH_SIZE=100
SELK_ENGINE_FLUSH_INTERVAL_MS=50
SELK_ENGINE_QUEUE_SIZE=1000
SELK_ENGINE_ES_ENDPOINT=http://127.0.0.1:9200
SELK_ENGINE_ES_INDEX=selk-suricata-%{+YYYY.MM.dd}

# ----- probe-dispatcher / asset publishing -----
SELK_RUNTIME_BIND=0.0.0.0
SELK_RUNTIME_PORT=19091
SELK_RUNTIME_POLL_SECONDS=60
SELK_RUNTIME_STALE_SECONDS=300
SELK_DISPATCH_AUTH_MODE=hmac
SELK_DISPATCH_KEY_ID=probe-prod-dispatcher
SELK_DISPATCH_SHARED_SECRET_FILE=configs/dispatcher.shared_secret
SELK_DISPATCH_BEARER_TOKEN=
SELK_DISPATCH_BEARER_TOKEN_FILE=

# Relative paths below are resolved against the deployed monitor&deploy directory.
SELK_ASSET_CONFIG_ROOT=assets

