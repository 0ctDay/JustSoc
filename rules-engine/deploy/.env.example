# =============================================================================
# JustSoc 探针层 Kafka 配置 — 复制为 .env 后按需修改（docker compose 会自动读取）
#
# Kafka 与 Suricata + probe + engine + monitor 同机部署。
# 这里是 Kafka 地址与密码的唯一来源；应用层 (仓库根 .env) 中 logstash 的
# KAFKA_BOOTSTRAP / KAFKA_SASL_* 必须与此处保持一致。
# =============================================================================

# 对外通告地址：填本机可被 logstash(远程) 及 probe/engine(同机) 访问到的 IP/域名
KAFKA_EXTERNAL_HOST=<probe-host-ip-or-domain>
KAFKA_EXTERNAL_PORT=9092

# SASL/PLAIN 账号密码（broker / init-topics / logstash / probe / engine 必须一致）
KAFKA_SASL_USERNAME=kafka
KAFKA_SASL_PASSWORD=<change-me>
