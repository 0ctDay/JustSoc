# Platform HTTP port on the Docker host.
PLATFORM_PORT=3000

# PostgreSQL used by Platform.
POSTGRES_DB=selk_controlplane
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<change-me>

# Fill these after you add or expose your ELK/Elasticsearch stack.
SELK_ELASTICSEARCH_URL=http://elasticsearch:9200
SELK_ELASTICSEARCH_USERNAME=
SELK_ELASTICSEARCH_PASSWORD=

# Authentication.
SELK_DEFAULT_USER_KEY=default
SELK_AUTH_SECRET=change-this-to-a-long-random-secret
SELK_AUTH_SESSION_HOURS=12

# AI integration.
SELK_AI_BASE_URL=
SELK_AI_API_KEY=
SELK_AI_MODEL=gpt-4o-mini

# Probe runtime monitor / dispatcher compatibility.
SELK_RUNTIME_MONITOR_BASE_URL=http://host.docker.internal:19091
SELK_RUNTIME_MONITOR_TOKEN=
SELK_RUNTIME_MONITOR_METRICS_PATH=/_selk_internal/v1/runtime-pulse/9f3a7c4e61/metrics
SELK_RUNTIME_MONITOR_CONTROL_PATH=/_selk_internal/v1/control-plane/9f3a7c4e61/restart

# Probe dispatcher asset API paths.
SELK_DISPATCHER_ASSET_APPLY_PATH=/_selk_internal/v1/assets/apply
SELK_DISPATCHER_ASSET_VALIDATE_PATH=/_selk_internal/v1/assets/validate
SELK_DISPATCHER_ASSET_STATUS_PATH=/_selk_internal/v1/assets/status

# Optional integrations.
# Claude Code Bridge 与平台同容器运行，地址固定 http://127.0.0.1:4317，无需配置。
