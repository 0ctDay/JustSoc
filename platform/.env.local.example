# Local development environment for JustSoc Platform.
# Copy to .env.local and replace placeholder values with real secrets/endpoints.

# PostgreSQL used by the platform app.
SELK_PLATFORM_DATABASE_URL=postgresql://postgres:<change-me>@127.0.0.1:5432/selk_controlplane

# Elasticsearch used by overview, alerts, logs, and asset views.
SELK_ELASTICSEARCH_URL=http://127.0.0.1:9200
SELK_ELASTICSEARCH_USERNAME=
SELK_ELASTICSEARCH_PASSWORD=

# Authentication.
# Must be configured and should be at least 24 characters long.
SELK_AUTH_SECRET=change-this-to-a-long-random-secret
SELK_AUTH_SESSION_HOURS=12
SELK_DEFAULT_USER_KEY=default

# Optional AI defaults.
SELK_AI_BASE_URL=
SELK_AI_API_KEY=
SELK_AI_MODEL=gpt-4o-mini

# Claude Code Bridge 与平台同容器运行，地址已硬编码为 http://127.0.0.1:4317，无需配置。

# Legacy runtime monitor / restart compatibility.
# Only needed if you still use the old single-probe runtime monitor flow.
SELK_RUNTIME_MONITOR_BASE_URL=http://127.0.0.1:19091
SELK_RUNTIME_MONITOR_TOKEN=
SELK_RUNTIME_MONITOR_METRICS_PATH=/_selk_internal/v1/runtime-pulse/9f3a7c4e61/metrics
SELK_RUNTIME_MONITOR_CONTROL_PATH=/_selk_internal/v1/control-plane/9f3a7c4e61/restart
SELK_RUNTIME_MONITOR_PROBE_NAME=probe1

# Probe-dispatcher asset API paths.
SELK_DISPATCHER_ASSET_APPLY_PATH=/_selk_internal/v1/assets/apply
SELK_DISPATCHER_ASSET_VALIDATE_PATH=/_selk_internal/v1/assets/validate
SELK_DISPATCHER_ASSET_STATUS_PATH=/_selk_internal/v1/assets/status
